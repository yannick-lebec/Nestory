# Neon (Postgres managed)
# Récupérer la connection string sur https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/nestory?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nestory-media
S3_ACCESS_KEY=nestory
S3_SECRET_KEY=nestory_dev
S3_REGION=us-east-1
